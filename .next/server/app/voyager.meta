{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/voyager/layout,_N_T_/voyager/page,_N_T_/voyager"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/voyager/__PAGE__",
    "/voyager",
    "/_index",
    "/_head"
  ]
}